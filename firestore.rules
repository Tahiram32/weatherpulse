rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clients/{domain} {
      allow read: if true;
      allow write: if false;
      
      match /private/{document=**} {
        allow read, write: if false; // Only accessible via firebase-admin
      }
      
      match /articles/{document=**} {
        allow read: if true;
        allow write: if false;
      }
    }
    match /runs/{runId} {
      allow read: if true;
      allow write: if false;
    }
    match /paypal_transactions/{txId} {
      // Disallow all client-side reads and deletes to prevent data harvesting and exfiltration
      allow read, delete: if false;
      
      // Allow creation with strict structural checks
      allow create: if request.resource.data.status in ['created', 'processing', 'completed', 'failed', 'refunded', 'denied', 'chargeback']
                    && request.resource.data.keys().hasAll(['status']);
                    
      // Enforce the transaction state machine at the database layer.
      allow update: if (
                      (resource.data.status == 'completed' && request.resource.data.status in ['completed', 'refunded', 'denied', 'chargeback']) ||
                      (resource.data.status == 'failed' && request.resource.data.status in ['failed', 'completed']) ||
                      (!(resource.data.status in ['completed', 'failed', 'refunded', 'denied', 'chargeback'])) ||
                      (resource.data.status == request.resource.data.status)
                    )
                    && (!request.resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt == resource.data.createdAt);
    }
  }
}
