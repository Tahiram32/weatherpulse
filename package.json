{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && NODE_ENV=production SANDBOX_MODE=true node dist/server.js",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "db:seed": "tsx seed.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.2.0",
    "@google-cloud/tasks": "^6.2.3",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@google/genai": "^2.4.0",
    "@paypal/react-paypal-js": "^10.1.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node-cron": "^3.0.11",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "geofire-common": "^6.0.0",
    "google-auth-library": "^10.9.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
