# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PAYPAL CREDENTIALS (Configure in your AI Studio Settings > Secrets)
# PayPal Environment: "sandbox" or "production"
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""

# FIREBASE ADMIN SERVICE ACCOUNT KEY (Configure in AI Studio Settings > Secrets)
# A stringified JSON of your Google Cloud Service Account Key with Cloud Datastore User permissions
FIREBASE_SERVICE_ACCOUNT_KEY=""

# ENTERPRISE WEATHER SLA API KEY (Optional - falls back to Open-Meteo/NWS if blank)
WEATHER_API_KEY=""

# GOOGLE CLOUD TASKS DISTRIBUTED QUEUE CONFIGURATION (Optional - falls back to high-fidelity Sim Queue if blank)
GCP_PROJECT_ID=""
GCP_LOCATION_ID=""
GCP_QUEUE_ID=""
GCP_SERVICE_ACCOUNT_EMAIL=""
TASK_WORKER_SECRET="sec_default_task_secret"

# FIREBASE CONFIGURATION (Optional - falls back to auto-provisioned configuration in AI Studio)
# Server-side Firebase Admin config
FIREBASE_PROJECT_ID=""
FIREBASE_FIRESTORE_DATABASE_ID=""

# METEOROLOGICAL SYNC TUNING & SCALABILITY CONFIGURATION
# Controls execution concurrency limit (set higher for paid tier accounts)
WEATHER_SYNC_CONCURRENCY=1
# Controls spacing delay between API requests in milliseconds to respect rate limits
WEATHER_SYNC_THROTTLE_MS=14000
# Real-time Dead-Letter Queue alerting webhook (Slack / Discord / PagerDuty URL)
WEATHER_SYNC_ALERT_WEBHOOK_URL=""

# MICROSERVICE DEPLOYMENT CONTEXT (Optional)
# Defines server role in serverless split architecture: 
# "gateway" (exposes only public webhook receiver), 
# "worker" (exposes only private IAM-secured tasks queue receiver), 
# "unified" (default; runs both in a single monolithic container for dev/sandbox).
SERVICE_ROLE="unified"

# For split microservice deployments:
# PRIVATE_WORKER_URL is the private URL of Service B (the background worker) which
# Cloud Tasks queue should target. In the gateway, if this is configured, it overrides
# the default APP_URL to direct traffic securely to the isolated worker.
PRIVATE_WORKER_URL=""

# Client-side (Vite) Firebase config
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""

